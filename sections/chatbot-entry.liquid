{% if section.settings.show_chat_teaser %}
<div class="chatbot-placeholder">
  <div class="card" style="max-width:280px;">
    <div class="badge">{{ section.settings.badge }}</div>
    <h4 style="margin:8px 0 6px;">{{ section.settings.heading }}</h4>
    <p class="note">{{ section.settings.text }}</p>
    <a class="button button--primary" href="{{ section.settings.link }}">{{ section.settings.button }}</a>
  </div>
</div>
{% endif %}
{% schema %}
{
  "name":"Chatbot entry",
  "settings":[
    {"type":"checkbox","id":"show_chat_teaser","label":"Hiển thị teaser", "default": true},
    {"type":"text","id":"badge","label":"Nhãn", "default":"AI support ready"},
    {"type":"text","id":"heading","label":"Tiêu đề", "default":"Cần gợi ý sản phẩm phù hợp?"},
    {"type":"textarea","id":"text","label":"Mô tả", "default":"Điểm kết nối cho chatbot/app embed trong tương lai. Hiện tại bạn có thể nhắn đội ngũ tư vấn thủ công."},
    {"type":"url","id":"link","label":"Link hỗ trợ"},
    {"type":"text","id":"button","label":"Nút", "default":"Mở hỗ trợ"}
  ]
}
{% endschema %}
