<section class="section">
  <div class="page-width grid grid--3" style="align-items:start;">
    <div class="card" style="grid-column:span 2;">
      <h2>{{ product.title }}</h2>
      <p class="note">{{ product.description | strip_html | truncate: 180 }}</p>
      <div class="grid grid--3">
        {% for media in product.media limit: 3 %}
          <div class="card">{{ media | image_url: width: 800 | image_tag: loading: 'lazy' }}</div>
        {% else %}
          <div class="card">Chưa có media. Hãy thêm ảnh mockup trong admin sản phẩm.</div>
        {% endfor %}
      </div>
    </div>

    <div class="card sticky-mobile-cta">
      {% form 'product', product %}
        <h3>{{ product.price | money }}</h3>
        {% unless product.has_only_default_variant %}
          <div class="product-form__field">
            <label class="required">Biến thể</label>
            <select name="id" required>
              {% for variant in product.variants %}<option value="{{ variant.id }}">{{ variant.title }}</option>{% endfor %}
            </select>
          </div>
        {% else %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        {% endunless %}

        <div class="product-form__field"><label class="required">Số lượng</label><input type="number" name="quantity" value="1" min="1"></div>
        <div class="product-form__field"><label class="required">Tải ảnh thật / ảnh mẫu</label><input type="text" name="properties[Link ảnh tham chiếu]" placeholder="Dán link Google Drive/Dropbox..." required><p class="note">MVP theme-only: Shopify line item properties không lưu file trực tiếp ổn định, dùng link ảnh để đội ngũ xử lý.</p></div>
        <div class="product-form__field"><label class="required">Mô tả yêu cầu cá nhân hoá</label><textarea name="properties[Yêu cầu cá nhân hoá]" rows="4" required placeholder="Ví dụ: đổi tông màu pastel, thêm tên Linh, phong cách tối giản..."></textarea></div>
        <div class="product-form__field"><label>Phong cách mong muốn</label><select name="properties[Phong cách]"><option>Tối giản</option><option>Dễ thương</option><option>Sang trọng</option><option>Vintage</option></select></div>
        <div class="product-form__field"><label>Màu chủ đạo</label><input type="text" name="properties[Màu chủ đạo]" placeholder="Ví dụ: hồng nude, xanh navy..."></div>
        <div class="product-form__field"><label>Ghi chú thêm</label><textarea name="properties[Ghi chú thêm]" rows="3"></textarea></div>

        <div class="card" style="padding:12px;background:#f9f7ff;">
          <strong>Luồng xử lý đơn trung gian</strong>
          <ul class="note" style="padding-left:18px;">
            <li>Bạn gửi yêu cầu</li>
            <li>Đội ngũ kiểm tra khả thi & xác nhận</li>
            <li>Chuyển cho đối tác sản xuất phù hợp</li>
            <li>Sản xuất sau khi duyệt</li>
            <li>Giao hàng hoàn thiện</li>
          </ul>
        </div>

        <div class="card" style="padding:12px;margin-top:12px;">
          <div class="badge">AI preview ready</div>
          <p class="note" style="margin:8px 0 0;">Placeholder: Đang xử lý ảnh → Xem trước mockup → Chờ đội ngũ xác nhận (cần app/backend ở giai đoạn sau).</p>
        </div>

        <button class="button button--primary" type="submit" style="width:100%;margin-top:14px;">Gửi yêu cầu thiết kế / thêm vào giỏ</button>
      {% endform %}
      <p class="note">Thời gian phản hồi kiểm duyệt: 4–24h. Sản xuất và giao hàng tuỳ danh mục.</p>
    </div>
  </div>
</section>

<section class="section">
  <div class="page-width card">
    <h2>FAQ sản phẩm cá nhân hoá</h2>
    <p><strong>Đơn nào cũng được duyệt ngay?</strong><br>Không. Đơn cần đội ngũ kiểm tra chất lượng ảnh và tính khả thi trước khi chuyển đối tác sản xuất.</p>
    <p><strong>Có chỉnh sửa sau khi gửi?</strong><br>Có thể, trước khi chốt duyệt sản xuất.</p>
  </div>
</section>
{% schema %}
{
  "name":"Main product POD",
  "settings":[],
  "presets":[{"name":"Main product POD"}]
}
{% endschema %}
